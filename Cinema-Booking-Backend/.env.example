# ---- Core (required) ----
PORT=5001
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Phase 2 (auth extension) — safe to leave blank in dev ----
# If ACCESS/REFRESH secrets are blank, JWT_SECRET is used as a fallback.
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Email (Nodemailer). If SMTP_* are blank in development, an Ethereal
# test account is created automatically and a preview URL is logged.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Cinema Booking <no-reply@cinema.local>"
APP_URL=http://localhost:5173
